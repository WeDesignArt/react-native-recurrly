# Copy this file to .env and fill in your own values.
# Never commit .env — it is listed in .gitignore.

# Clerk publishable key
# Found in the Clerk Dashboard → API Keys → Quick Copy
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY_HERE

# PostHog analytics
# Found in PostHog → Project Settings → Project API Key
EXPO_PUBLIC_POSTHOG_KEY=YOUR_POSTHOG_PROJECT_API_KEY_HERE
# Use https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU)
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# logo.dev — public key only (safe for client-side use)
# Get yours at https://logo.dev → Dashboard → API Keys
# Secret key must never be committed
EXPO_PUBLIC_LOGO_DEV_KEY=YOUR_LOGO_DEV_PUBLIC_KEY_HERE
